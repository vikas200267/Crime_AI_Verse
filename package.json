    "lucide-react": "^0.395.0",
    "motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/canvas-confetti": "^1.6.4",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.21.5",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
